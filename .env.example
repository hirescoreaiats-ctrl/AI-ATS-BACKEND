# Application
ENVIRONMENT=development
APP_NAME=Enterprise AI ATS
API_PREFIX=/api/v1
FRONTEND_URL=http://127.0.0.1:5500
APP_PUBLIC_BASE_URL=http://127.0.0.1:8000
FRONTEND_SIGNUP_PATH=frontend/Signup.html
FRONTEND_LOGIN_PATH=frontend/login.html
FRONTEND_PRICING_PATH=frontend/pricing.html
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5173,http://127.0.0.1:5173

# Data stores
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>
POSTGRES_DB=<db_name>
# Supabase Postgres usually uses the pooler host/port shown in Supabase dashboard.
DATABASE_URL=postgresql+psycopg://<db_user>:<db_password>@<supabase_pooler_host>:6543/<db_name>?sslmode=require
REDIS_URL=redis://<redis_host>:6379/0

# Resume file storage
STORAGE_BACKEND=supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
SUPABASE_STORAGE_BUCKET=resumes
SUPABASE_DELETE_LOCAL_AFTER_UPLOAD=true

# Security
JWT_SECRET=<replace-with-long-random-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=1440
SIGNUP_MODE=access_code
PAID_SIGNUP_ACCESS_CODES=<paid-access-code>
CHECKOUT_URL=https://example.com/checkout
SALES_CONTACT_EMAIL=sales@example.com
CANDIDATE_TRACKING_TOKEN_DAYS=30
ALLOW_LEGACY_CANDIDATE_TRACKING=true
SECURE_COOKIES=false
CSRF_COOKIE_NAME=ats_csrf
RATE_LIMIT_PER_MINUTE=120
MAX_UPLOAD_MB=10
UPLOAD_DIR=uploads
SENTRY_DSN=

# Google OAuth / Gmail / Forms
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/google-callback

# Email provider option A: Resend
RESEND_API_KEY=<resend-api-key>
RESEND_FROM=AI ATS <recruiting@example.com>

# Email provider option B: SMTP
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_USER=<smtp-user>
SMTP_USERNAME=<smtp-user>
SMTP_PASSWORD=<smtp-password>
SMTP_FROM=<smtp-from-address>
SMTP_FROM_EMAIL=<smtp-from-address>
SUPPORT_TO_EMAIL=hirescoreaiats@gmail.com

# AI
OPENAI_API_KEY=<openai-api-key>
OPENAI_RESUME_PARSE_MODEL=gpt-4.1-mini
OPENAI_RESUME_REPAIR_MODEL=gpt-5-mini
OPENAI_RECOMMENDATION_MODEL=gpt-4o-mini

# Assessments
ASSESSMENT_QUESTION_COUNT=20
ASSESSMENT_DURATION_MINUTES=30
ASSESSMENT_PASS_PERCENT=60
