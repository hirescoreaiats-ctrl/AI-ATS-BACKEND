ENVIRONMENT=production
API_PREFIX=/api/v1
APP_PUBLIC_BASE_URL=https://api.example.com
# Public frontend origin used by Google OAuth/payment redirects.
# Temporary Vercel setup: set this to the exact Vercel production URL currently used by clients.
# Example: https://your-project.vercel.app
FRONTEND_URL=https://your-project.vercel.app
FRONTEND_SIGNUP_PATH=Signup.html
FRONTEND_LOGIN_PATH=login.html
FRONTEND_PRICING_PATH=pricing.html
DATABASE_URL=postgresql+psycopg://<db_user>:<db_password>@<supabase_pooler_host>:6543/<db_name>?sslmode=require
REDIS_URL=redis://<redis_host>:6379/0
STORAGE_BACKEND=vercel_blob
STORAGE_PROVIDER=vercel_blob
BLOB_STORE_ID=<vercel-blob-store-id>
BLOB_READ_WRITE_TOKEN=<vercel-blob-read-write-token>
MAX_RESUME_SIZE_MB=20
# Optional only if you keep using Cloudflare R2 instead of Vercel Blob:
# STORAGE_BACKEND=r2
# R2_ENDPOINT_URL=https://<cloudflare-account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=<r2-access-key-id>
# R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
# R2_BUCKET=resumes
# R2_DELETE_LOCAL_AFTER_UPLOAD=true
# Optional only if you keep using Supabase storage instead of R2:
# STORAGE_BACKEND=supabase
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
# SUPABASE_STORAGE_BUCKET=resumes
# SUPABASE_DELETE_LOCAL_AFTER_UPLOAD=true
ALLOWED_ORIGINS=https://your-project.vercel.app,https://app.example.com
# Temporary only: allow Vercel preview URLs. Remove this after final custom domain is stable.
ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app
JWT_SECRET=<replace-with-strong-production-secret>
SIGNUP_MODE=access_code
PAID_SIGNUP_ACCESS_CODES=<paid-access-code-from-checkout>
CHECKOUT_URL=https://example.com/checkout
SALES_CONTACT_EMAIL=sales@example.com
GOOGLE_REDIRECT_URI=https://api.example.com/google-callback
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
CANDIDATE_TRACKING_TOKEN_DAYS=30
ALLOW_LEGACY_CANDIDATE_TRACKING=false
SECURE_COOKIES=true
# Set 0 to disable app-level rate limiting behind a trusted proxy/load balancer.
RATE_LIMIT_PER_MINUTE=600
MAX_UPLOAD_MB=20
SENTRY_DSN=
OPENAI_API_KEY=<openai-api-key>
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>
POSTGRES_DB=<db_name>
